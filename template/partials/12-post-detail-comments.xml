            <b:includable id='postDetail' var='post'>
              <div aria-labelledby='gg-detail-toolbar-title' class='gg-detail-toolbar' role='toolbar'>
                <span class='gg-visually-hidden' data-gg-copy='detail.toolbar' id='gg-detail-toolbar-title'>Detail actions</span>
                <button aria-controls='gg-comments-sheet' aria-expanded='false' class='gg-detail-toolbar__action' data-gg-action='comments-open' type='button'>
                  <span class='gg-detail-toolbar__count' id='gg-detail-comments-count'><data:post.numberOfComments/></span>
                  <span aria-hidden='true' class='gg-icon'>comment</span>
                  <span data-gg-copy='comments.launch' id='gg-detail-comments-label'>Comments</span>
                </button>
              </div>

              <article class='gg-article' expr:data-gg-post-author='data:post.author.name.escaped' expr:data-gg-post-comments='data:post.numberOfComments' expr:data-gg-post-published='data:post.date and data:post.date.iso8601 ? data:post.date.iso8601 : &quot;&quot;' expr:data-gg-post-title='data:post.title.escaped' expr:data-gg-post-updated='data:post.lastUpdated and data:post.lastUpdated.iso8601 and data:post.date and data:post.date.iso8601 and data:post.lastUpdated.iso8601 != data:post.date.iso8601 ? data:post.lastUpdated.iso8601 : &quot;&quot;' expr:data-gg-post-url='data:post.url'>
                <nav aria-labelledby='gg-breadcrumb-title' class='gg-breadcrumbs'>
                  <span class='gg-visually-hidden' data-gg-copy='post.breadcrumb' id='gg-breadcrumb-title'>Breadcrumb</span>
                  <a data-gg-copy='post.blog' href='/'>Blog</a>
                  <b:if cond='data:post.labels'>
                    <span aria-hidden='true'>/</span>
                    <a expr:href='data:post.labels.first.url'><data:post.labels.first.name/></a>
                  </b:if>
                </nav>

                <h1 class='gg-article__title'><data:post.title/></h1>

                <b:include data='post' name='postBody'/>
                <footer class='gg-article__tail'>
                  <p class='gg-article__tail-line'>
                    <span class='gg-meta__cue' data-gg-copy='post.by'>By</span>
                    <span class='gg-meta__value'><data:post.author.name/></span>
                  </p>
                  <b:if cond='(data:post.date and data:post.date.iso8601) or (data:post.lastUpdated and data:post.lastUpdated.iso8601 and data:post.date and data:post.date.iso8601 and data:post.lastUpdated.iso8601 != data:post.date.iso8601)'>
                    <p class='gg-article__tail-line'>
                      <b:if cond='data:post.date and data:post.date.iso8601'>
                        <span class='gg-article__tail-part'>
                          <span class='gg-meta__cue' data-gg-copy='post.published'>Published</span>
                          <time class='gg-meta__value' expr:datetime='data:post.date.iso8601'><data:post.date/></time>
                        </span>
                      </b:if>
                      <b:if cond='data:post.lastUpdated and data:post.lastUpdated.iso8601 and data:post.date and data:post.date.iso8601 and data:post.lastUpdated.iso8601 != data:post.date.iso8601'>
                        <span class='gg-article__tail-part'>
                          <span class='gg-meta__cue' data-gg-copy='post.updated'>Updated</span>
                          <time class='gg-meta__value' expr:datetime='data:post.lastUpdated.iso8601'><data:post.lastUpdated/></time>
                        </span>
                      </b:if>
                    </p>
                  </b:if>

                  <b:if cond='data:post.labels'>
                    <p class='gg-article__tail-line'>
                      <span class='gg-meta__cue' data-gg-copy='post.in'>In</span>
                      <span class='gg-taxonomy'>
                        <b:loop values='data:post.labels' var='label'>
                          <span class='gg-taxonomy__item'>
                            <a class='gg-taxonomy__link' expr:href='data:label.url'><data:label.name/></a>
                          </span>
                        </b:loop>
                      </span>
                    </p>
                  </b:if>
                </footer>
              </article>

              <nav aria-label='Contents' class='gg-detail-outline' data-gg-copy-aria-label='outline.title' data-gg-outline-state='peek' hidden='hidden' id='gg-detail-outline'>
                <button aria-controls='gg-detail-outline-tray' aria-expanded='false' class='gg-detail-outline__peek' data-gg-outline-toggle='true' id='gg-detail-outline-toggle' type='button'>
                  <span class='gg-detail-outline__peek-main'>
                    <span class='gg-detail-outline__label' data-gg-copy='outline.title'>Contents</span>
                    <strong class='gg-detail-outline__current' id='gg-detail-outline-current'><data:post.title/></strong>
                  </span>
                  <span class='gg-detail-outline__summary' hidden='hidden' id='gg-detail-outline-summary'/>
                  <span aria-hidden='true' class='gg-detail-outline__affordance'>
                    <span aria-hidden='true' class='gg-detail-outline__handle'/>
                    <span aria-hidden='true' class='gg-icon' id='gg-detail-outline-glyph'>keyboard_arrow_up</span>
                  </span>
                  <progress aria-hidden='true' class='gg-detail-outline__progress' id='gg-detail-outline-progress' max='1' tabindex='-1' value='0'>0</progress>
                </button>
                <div class='gg-detail-outline__tray' hidden='hidden' id='gg-detail-outline-tray'>
                  <ol class='gg-detail-outline__list' id='gg-detail-outline-list'/>
                </div>
                <template id='gg-detail-outline-empty-template'>
                  <li class='gg-detail-outline__empty' data-gg-template-part='text'/>
                </template>
                <template id='gg-detail-outline-group-template'>
                  <li class='gg-detail-outline__group'>
                    <button class='gg-detail-outline__item-button' data-gg-template-part='button' type='button'>
                      <span class='gg-detail-outline__item-label' data-gg-template-part='label'/>
                    </button>
                    <ol class='gg-detail-outline__sublist' data-gg-template-part='sublist' hidden='hidden'/>
                  </li>
                </template>
                <template id='gg-detail-outline-item-template'>
                  <li class='gg-detail-outline__item'>
                    <button class='gg-detail-outline__item-button' data-gg-template-part='button' type='button'>
                      <span class='gg-detail-outline__item-label' data-gg-template-part='label'/>
                    </button>
                  </li>
                </template>
              </nav>

              <div aria-hidden='true' class='gg-comments-sheet gg-sheet gg-sheet--bottom' data-gg-edge='bottom' data-gg-module='gg-comments-sheet' data-gg-panel-family='utility-sheet' data-gg-sheet='comments' data-gg-state='closed' hidden='hidden' id='gg-comments-sheet' inert='' tabindex='-1'>
                <button class='gg-comments-sheet__scrim gg-sheet__scrim' data-gg-action='comments-close' type='button'>
                  <span class='gg-visually-hidden' data-gg-copy='comments.dismiss'>Dismiss comments panel</span>
                </button>
                <section aria-labelledby='gg-comments-title' aria-modal='true' class='gg-comments-sheet__panel gg-sheet__panel' role='dialog' tabindex='-1'>
                  <header class='gg-comments-sheet__head gg-sheet__head'>
                    <button class='gg-comments-sheet__handle gg-sheet__handle' data-gg-action='comments-close' data-gg-drag-handle='comments' type='button'>
                      <span class='gg-visually-hidden' data-gg-copy='comments.dismiss'>Dismiss comments panel</span>
                    </button>
                    <h2 class='gg-comments-sheet__title gg-sheet__title' id='gg-comments-title'>
                      <span data-gg-copy='comments.title' id='gg-comments-title-text'>Comments</span>
                    </h2>
                  </header>
                  <section class='gg-comments gg-comments--sheet comments2 threaded' data-gg-comment-engine='blogger-native' data-gg-module='gg-comments' expr:data-embed='data:post.embedCommentForm' expr:data-num-comments='data:post.numberOfComments' id='gg-comments-root'>
                    <a id='comments' name='comments'/>
                    <div class='gg-comments__content'>
                      <b:if cond='data:post.embedCommentForm'>
                        <b:include data='post' name='threadedCommentJs'/>
                      </b:if>
                      <div class='gg-comments__list' data-gg-role='comments-list' id='gg-comments-list'>
                        <data:post.commentHtml/>
                      </div>
                    </div>
                    <footer class='gg-comments__footer' data-gg-role='comments-footer' id='gg-comments-footer'>
                      <b:if cond='data:post.allowNewComments'>
                        <button data-gg-action='comments-open-composer' type='button'>Add comment</button>
                      </b:if>
                      <div data-gg-slot='gg-comments-reply' id='gg-comments-reply-slot'/>
                      <div data-gg-slot='gg-comments-composer' id='gg-comments-composer-slot'>
                        <div class='gg-comments__composer' id='gg-comments-composer'>
                          <b:if cond='data:post.allowNewComments'>
                            <div class='comment-form' data-gg-native-plumbing='composer' id='top-ce'>
                              <a id='comment-form' name='comment-form'/>
                              <h4 id='comment-post-message'><data:messages.postAComment/></h4>
                              <b:if cond='data:this.messages.blogComment != &quot;&quot;'>
                                <p><data:this.messages.blogComment/></p>
                              </b:if>
                              <b:include data='post' name='commentFormIframeSrc'/>
                              <iframe allowtransparency='allowtransparency' class='blogger-iframe-colorize blogger-comment-from-post' expr:height='data:cmtIframeInitialHeight ?: &quot;90px&quot;' frameborder='0' id='comment-editor' name='comment-editor' src='' width='100%'/>
                              <data:post.cmtfpIframe/>
                              <script type='text/javascript'>
                                BLOG_CMT_createIframe(&#39;<data:post.appRpcRelayPath/>&#39;);
                              </script>
                            </div>
                          <b:else/>
                            <p class='gg-comments__closed'><data:post.noNewCommentsText/></p>
                          </b:if>
                        </div>
                      </div>
                      <b:if cond='data:post.showManageComments'>
                        <b:include data='post' name='manageComments'/>
                      </b:if>
                    </footer>
                    <b:if cond='data:showCmtPopup'>
                      <div id='comment-popup'>
                        <iframe allowtransparency='allowtransparency' frameborder='0' id='comment-actions' name='comment-actions' scrolling='no'>
                        </iframe>
                      </div>
                    </b:if>
                  </section>
                </section>
              </div>

              <div aria-hidden='true' class='gg-comments-sheet gg-comments-sheet--replies gg-sheet gg-sheet--bottom' data-gg-edge='bottom' data-gg-module='gg-comment-replies-sheet' data-gg-panel-family='utility-sheet' data-gg-sheet='comment-replies' data-gg-state='closed' hidden='hidden' id='gg-comment-replies-sheet' inert='' tabindex='-1'>
                <button class='gg-comments-sheet__scrim gg-sheet__scrim' data-gg-action='comments-replies-close' type='button'>
                  <span class='gg-visually-hidden'>Dismiss replies</span>
                </button>
                <section aria-labelledby='gg-comment-replies-title' aria-modal='true' class='gg-comments-sheet__panel gg-sheet__panel' role='dialog' tabindex='-1'>
                  <header class='gg-comments-sheet__head gg-sheet__head'>
                    <button aria-label='Back to comments' class='gg-comments-sheet__back' data-gg-action='comments-replies-close' type='button'>
                      <span aria-hidden='true'>&#8249;</span>
                    </button>
                    <h2 class='gg-comments-sheet__title gg-sheet__title' id='gg-comment-replies-title'>Replies</h2>
                  </header>
                  <section class='gg-comments gg-comments--sheet comments2 threaded' data-gg-comment-engine='blogger-native' data-gg-module='gg-comment-replies' id='gg-comment-replies-root'>
                    <div class='gg-comments__content'>
                      <div class='gg-comment-replies__context' id='gg-comment-replies-context'/>
                      <div class='gg-comments__list gg-comment-replies__list' data-gg-role='comment-replies-list' id='gg-comment-replies-list'/>
                    </div>
                    <footer class='gg-comments__footer gg-comment-replies__footer' data-gg-role='comment-replies-footer' id='gg-comment-replies-footer'/>
                  </section>
                </section>
              </div>
            </b:includable>
