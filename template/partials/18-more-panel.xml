    <div class='gg-sheet gg-sheet--bottom' data-gg-edge='bottom' data-gg-panel='more' data-gg-panel-family='utility-sheet' data-gg-state='closed' hidden='hidden' id='gg-more-panel'>
      <button class='gg-sheet__scrim' data-gg-close='more' type='button'>
        <span class='gg-visually-hidden' data-gg-copy='more.dismiss'>Dismiss more panel</span>
      </button>
      <section aria-labelledby='gg-more-title' aria-modal='true' class='gg-more-sheet gg-sheet__panel' role='dialog' tabindex='-1'>
        <div class='gg-sheet__head'>
          <div aria-hidden='true' class='gg-sheet__handle' data-gg-drag-handle='more'/>
          <h2 class='gg-sheet__title' data-gg-copy='more.title' id='gg-more-title'>More</h2>
        </div>

        <div class='gg-more-list'>
          <a class='gg-more-list__link' data-gg-copy='more.blog' href='/'>Blog</a>
          <a class='gg-more-list__link' data-gg-copy='more.search' expr:href='data:blog.searchUrl'>Search</a>
          <a class='gg-more-list__link' data-gg-copy='more.sitemap' href='/sitemap.xml'>Sitemap</a>
          <a class='gg-more-list__link' data-gg-copy='more.rss' href='/feeds/posts/default?alt=rss'>RSS</a>
        </div>

        <div class='gg-langswitch' data-gg-module='language'>
          <p class='gg-langswitch__title' data-gg-copy='language.label' id='gg-language-title'>Language</p>
          <div aria-labelledby='gg-language-title' class='gg-langswitch__actions' role='group'>
            <button aria-pressed='false' class='gg-langswitch__button' data-gg-active='false' data-gg-copy='language.en' data-gg-lang-option='en' type='button'>EN</button>
            <button aria-pressed='false' class='gg-langswitch__button' data-gg-active='false' data-gg-copy='language.id' data-gg-lang-option='id' type='button'>ID</button>
          </div>
        </div>
        <div class='gg-appearance' data-gg-module='appearance'>
          <p class='gg-appearance__title' data-gg-copy='appearance.label' id='gg-appearance-title'>Appearance</p>
          <div aria-labelledby='gg-appearance-title' class='gg-appearance__actions' role='group'>
            <button aria-pressed='false' class='gg-appearance__button' data-gg-active='false' data-gg-copy='appearance.system' data-gg-theme-option='system' type='button'>System</button>
            <button aria-pressed='false' class='gg-appearance__button' data-gg-active='false' data-gg-copy='appearance.light' data-gg-theme-option='light' type='button'>Light</button>
            <button aria-pressed='false' class='gg-appearance__button' data-gg-active='false' data-gg-copy='appearance.dark' data-gg-theme-option='dark' type='button'>Dark</button>
          </div>
        </div>
        <footer class='gg-more-footer'>
          <div aria-labelledby='gg-more-footer-social-title' class='gg-more-footer__social'>
            <span class='gg-visually-hidden' data-gg-copy='more.channelsLabel' id='gg-more-footer-social-title'>Share site</span>
            <a class='gg-more-footer__link' data-gg-copy-aria-label='more.shareX' data-gg-copy-title='more.shareX' expr:href='&quot;https://twitter.com/intent/tweet?url=&quot; + data:blog.homepageUrl' rel='noopener noreferrer' target='_blank' title='Share on X'>X</a>
            <a class='gg-more-footer__link' data-gg-copy-aria-label='more.shareFacebook' data-gg-copy-title='more.shareFacebook' expr:href='&quot;https://www.facebook.com/sharer/sharer.php?u=&quot; + data:blog.homepageUrl' rel='noopener noreferrer' target='_blank' title='Share on Facebook'>Fb</a>
            <a class='gg-more-footer__link' data-gg-copy-aria-label='more.shareWhatsApp' data-gg-copy-title='more.shareWhatsApp' expr:href='&quot;https://api.whatsapp.com/send?text=&quot; + data:blog.homepageUrl' rel='noopener noreferrer' target='_blank' title='Share on WhatsApp'>Wa</a>
          </div>
          <small class='gg-more-footer__legal' data-gg-copy='more.rights'>Copyright &#169; 2026 PakRPP. All rights reserved.</small>
        </footer>
      </section>
    </div>
