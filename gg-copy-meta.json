      &quot;name&quot;: &quot;<b:if cond='data:post.author and data:post.author.name'><data:post.author.name.escaped/><b:else/>PakRPP</b:if>&quot;
    },
    &quot;publisher&quot;: {
      &quot;@type&quot;: &quot;Organization&quot;,
      &quot;name&quot;: &quot;<data:blog.title.escaped/>&quot;<b:if cond='data:blog.logoUrl'>,
      &quot;logo&quot;: {
        &quot;@type&quot;: &quot;ImageObject&quot;,
        &quot;url&quot;: &quot;<data:blog.logoUrl/>&quot;
      }</b:if>
    }<b:if cond='data:post.firstImageUrl'>,
    &quot;image&quot;: [&quot;<data:post.firstImageUrl/>&quot;]</b:if>
  }
  </script>

