# PakRPP static asset headers — development-safe baseline
# Worker remains the primary route-policy layer. These headers protect static assets
# when served directly by Cloudflare Pages/Assets.

/*
  X-GG-Assets: ac33998
  X-GG-Static-Policy: development-safe
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), bluetooth=(), midi=(), magnetometer=(), gyroscope=(), accelerometer=()

/sw.js
  Content-Type: application/javascript; charset=utf-8
  Cache-Control: no-store
  Service-Worker-Allowed: /
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/offline.html
  Content-Type: text/html; charset=utf-8
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow, nosnippet, noimageindex, max-snippet:0, max-image-preview:none, max-video-preview:0
  X-GG-Assets: ac33998

/manifest.webmanifest
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/gg-flags.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/flags.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/__gg/assets/*.css
  Content-Type: text/css; charset=utf-8
  Cache-Control: no-store
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/__gg/assets/*.js
  Content-Type: application/javascript; charset=utf-8
  Cache-Control: no-store
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/__gg/*.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/__gg/assets/*.css
  Content-Type: text/css; charset=utf-8
  Cache-Control: no-store
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex, nofollow

/__gg/assets/*.js
  Content-Type: application/javascript; charset=utf-8
  Cache-Control: no-store
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex, nofollow

/__gg/*.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: no-store
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex, nofollow

/__gg/*
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/ads.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/assets/latest/*
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/assets/v/*
  Cache-Control: public, max-age=31536000, immutable
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998

/gg-pwa-icon/*
  Cache-Control: public, max-age=31536000, immutable
  X-Robots-Tag: noindex, nofollow
  X-GG-Assets: ac33998
