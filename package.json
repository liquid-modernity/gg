{
  "name": "gg-vnext",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "doctor": "node tools/doctor.mjs",
    "build": "node tools/build.mjs --mode all",
    "build:dev": "node tools/build.mjs --mode dev",
    "build:prod": "node tools/build.mjs --mode prod",
    "check": "npm run doctor && node checks/build-output.check.mjs",
    "check:path": "node checks/path.check.mjs",
    "check:registry": "node checks/registry.check.mjs",
    "check:module": "node checks/module.check.mjs",
    "check:microcopy": "node checks/microcopy.check.mjs",
    "check:icon": "node checks/icon.check.mjs",
    "check:env": "node checks/env.check.mjs",
    "check:syntax": "node checks/syntax.check.mjs",
    "check:softcode": "node checks/softcode.check.mjs",
    "check:public-softcode": "node checks/public-softcode.check.mjs",
    "console": "node apps/console/server.mjs",
    "console:check": "node apps/console/server.mjs --check",
    "studio": "node apps/studio/server.mjs",
    "studio:check": "node apps/studio/server.mjs --check",
    "deploy:dry": "node tools/deploy.mjs --dry-run",
    "deploy": "node tools/deploy.mjs",
    "clean": "node tools/clean.mjs"
  },
  "devDependencies": {}
}