{
  "name": "gg",
  "private": true,
  "scripts": {
    "build": "npm run store:build && node tools/cloudflare-prepare.mjs",
    "gaga": "node tools/gaga-release.mjs ship",
    "gaga:dry": "node tools/gaga-release.mjs ship --dry-run",
    "gaga:push": "node tools/gaga-release.mjs ship",
    "gaga:preflight": "node tools/preflight.mjs",
    "store:build": "bash tools/store-build.sh",
    "store:proof": "node tools/proof-store-static.mjs",
    "gaga:template:pack": "node tools/template-pack.mjs",
    "gaga:cf:prepare": "npm run store:build && node tools/cloudflare-prepare.mjs",
    "gaga:cf:dry": "node tools/cloudflare-deploy.mjs dry-run",
    "gaga:cf:deploy": "node tools/cloudflare-deploy.mjs deploy",
    "gaga:template:status": "bash qa/template-status.sh",
    "gaga:template:proof": "bash qa/template-proof.sh",
    "gaga:verify-store-artifact": "npm run store:build && npm run store:proof && bash qa/store-artifact-smoke.sh",
    "gaga:verify-worker": "npm run store:build && npm run store:proof && bash qa/store-artifact-smoke.sh",
    "gaga:verify-worker-live": "bash qa/live-smoke-worker.sh \"${GG_LIVE_BASE_URL:-https://www.pakrpp.com}\""
  },
  "devDependencies": {
    "wrangler": "4.61.1"
  }
}
